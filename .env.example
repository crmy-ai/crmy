# ─────────────────────────────────────────────────────────────────────────────
# CRMy — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# The dev server auto-loads .env from the repo root (or packages/server/.env).
# .env files are gitignored; this .env.example file is checked in.
# ─────────────────────────────────────────────────────────────────────────────


# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Formats:
#   Local install:  postgresql://localhost:5432/crmy
#   Docker Compose: postgresql://crmy:crmy@db:5432/crmy
#   Supabase:       Project Settings → Database → Connection String
#   Neon:           Dashboard → Connection Details
DATABASE_URL=postgresql://localhost:5432/crmy

# Secret used to sign and verify JWT session tokens.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum recommended length: 32 bytes of entropy (64 hex chars).
# Changing this value invalidates all existing sessions.
JWT_SECRET=


# ── Server (optional) ─────────────────────────────────────────────────────────

# TCP port the HTTP server listens on. Default: 3000
# PORT=3000

# Tenant slug used when the server manages a single tenant directly.
# Matches the `slug` column in the `tenants` table. Default: default
# CRMY_TENANT_ID=default

# Node.js environment. Set to "production" in deployed environments to
# disable stack traces in error responses and enable other hardening.
# NODE_ENV=production

# Deployment envelope. Local and single-instance self-hosted installs work
# without extra routing. Multi-instance hosted deployments require a stable
# CRMY_INSTANCE_ID per app process and sticky MCP routing by mcp-session-id.
# CRMY_DEPLOYMENT_MODE=single_instance
# CRMY_INSTANCE_ID=web-1
# CRMY_MCP_SESSION_MODE=sticky
# CRMY_MCP_SESSION_TTL_SECONDS=1800
# CRMY_MCP_STALE_INSTANCE_SECONDS=120

# Database connection and query guardrails. Defaults keep local setup simple
# while preventing hung database calls from stalling production request paths.
# DB_CONNECTION_TIMEOUT_MS=10000
# DB_QUERY_TIMEOUT_MS=30000
# DB_STATEMENT_TIMEOUT_MS=30000

# Shared authenticated actor rate limit for REST and MCP requests. Local installs
# usually keep the defaults. Hosted deployments should tune these by plan.
# CRMY_ACTOR_RATE_LIMIT_MAX=600
# CRMY_ACTOR_RATE_LIMIT_WINDOW_MS=60000

# Hosted browser auth option. Keep unset for local CLI-managed installs. Set
# both flags for hosted web builds to store browser auth in an HttpOnly cookie
# instead of localStorage bearer tokens.
# CRMY_BROWSER_COOKIE_AUTH=true
# VITE_CRMY_BROWSER_COOKIE_AUTH=true


# ── Stored secret encryption (required in production) ─────────────────────────

# 256-bit (64 hex char) key used to encrypt connector credentials, mailbox/
# calendar OAuth tokens, and Workspace Agent provider keys stored in the DB.
# `crmy init` generates and saves this automatically for local CLI-managed
# installs. The local source dev server also generates and appends this to .env
# when JWT_SECRET is present but no encryption key is configured.
# Set it explicitly for production, containers, or custom process managers so
# every CRMy process uses the same persistent key.
# Required when NODE_ENV=production.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRMY_ENCRYPTION_KEY=
#
# Optional legacy/override key for Workspace Agent provider keys. Most installs
# should leave this unset and use CRMY_ENCRYPTION_KEY for all stored secrets.
# AGENT_ENCRYPTION_KEY=

# Explicit browser origins allowed to call the API cross-origin. Same-origin
# app usage does not require this. Comma-separated, e.g.:
# CRMY_CORS_ORIGINS=https://crm.company.com,https://agents.company.com
#
# Reverse proxy trust setting. Set to 1 when CRMy runs behind one trusted proxy
# so rate limits use the real client IP from X-Forwarded-For.
# CRMY_TRUST_PROXY=1
#
# Public base URL used for generated mailbox/calendar OAuth redirects when CRMy
# sits behind a tunnel, reverse proxy, or hosted domain. Do not include a
# trailing slash.
# CRMY_PUBLIC_URL=https://crmy.example.com


# ── First-run / headless init (optional) ──────────────────────────────────────

# On first boot with an empty database, the server auto-creates an owner
# account using these values. Remove (or unset) after the first successful
# start to avoid re-applying on subsequent restarts.
#
# If these are not set and no users exist, the server starts normally but
# prints a warning with instructions for creating the first account.
#
# See also: npx @crmy/cli init   (interactive wizard, recommended for local installs)
#           POST /auth/register  (REST API, works against any running server)
# CRMY_ADMIN_EMAIL=admin@yourcompany.com
# CRMY_ADMIN_PASSWORD=
# CRMY_ADMIN_NAME=Admin


# ── CLI / plugin overrides (optional) ─────────────────────────────────────────

# These are used by @crmy/cli and plugin clients to reach the server.
# In most setups these come from ~/.crmy/config.json (written by `crmy init`).
# Set them here to override the config file, e.g. in CI or container environments.

# Base URL of the CRMy server. Default: http://localhost:3000
# CRMY_SERVER_URL=http://localhost:3000

# API key for authenticating CLI and plugin requests.
# Obtain from: Settings → API Keys in the web UI, or `crmy auth login`.
# CRMY_API_KEY=


# ── LLM backend for auto-extraction of context from activities ─────────────────

# When configured, CRMy automatically extracts structured context entries
# (objections, preferences, competitive intel, etc.) from activity descriptions.
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514

# Hard timeout (milliseconds) for general background LLM calls.
# Applies via AbortController — prevents hung provider connections from blocking
# the extraction worker indefinitely. Default: 60000 (60 seconds).
# LLM_TIMEOUT_MS=60000
#
# Hard timeout (milliseconds) for streaming Workspace Agent provider calls.
# Default: 60000 (60 seconds).
# AGENT_STREAM_TIMEOUT_MS=60000
#
# Raw Context extraction needs a longer window than quick model checks because
# CRMy sends a rich extraction packet and asks for evidence-backed Signals.
# CONTEXT_EXTRACTION_LLM_TIMEOUT_MS=90000
# Optional shorter caps for fallback passes. These keep a bad model response
# from turning one paste into several long-running extraction attempts.
# CONTEXT_EXTRACTION_RECOVERY_TIMEOUT_MS=45000
# CONTEXT_EXTRACTION_REPAIR_TIMEOUT_MS=30000
#
# Automatic Raw Context subject matching stays shorter so record matching feels
# responsive before the full extraction pipeline runs.
# RAW_CONTEXT_SUBJECT_MATCH_TIMEOUT_MS=15000


# ── External HTTP timeouts (optional) ──────────────────────────────────────────
#
# Mailbox/calendar OAuth and provider fetch timeout. Default: 30000.
# SOURCE_SYNC_FETCH_TIMEOUT_MS=30000

# Hosted/SaaS deployments can use CRMy-managed provider apps by default so
# ordinary tenants do not need deployment-level OAuth secrets. Enterprise
# tenants can still configure tenant-owned OAuth apps from Settings → System
# Connections → OAuth. Local/self-hosted installs can ignore
# this block and use the self-hosted credentials below.
#
# CRMY_MANAGED_OAUTH_APPS_ENABLED=false
# CRMY_MANAGED_GOOGLE_CLIENT_ID=
# CRMY_MANAGED_GOOGLE_CLIENT_SECRET=
# CRMY_MANAGED_MICROSOFT_CLIENT_ID=
# CRMY_MANAGED_MICROSOFT_CLIENT_SECRET=
# CRMY_MANAGED_MICROSOFT_TENANT_ID=common

# ── Mailbox OAuth for Context + Sender Identity (optional) ───────────────────
#
# CRMy can connect Gmail/Google Workspace and Microsoft 365 mailboxes from
# /app/emails → Mailboxes & Senders. The UI asks whether the mailbox should be
# used for customer context, approved outbound sends, and provider drafts.
# Hosted tenants use CRMy-managed OAuth apps by default; enterprise tenants can
# save tenant-owned app credentials in System Connections; self-hosted installs
# use the env vars in this section.
#
# Google redirect URI:
#   http://localhost:3000/api/v1/mailbox/oauth/google/callback
#   https://your-crmy-host/api/v1/mailbox/oauth/google/callback
# Use the exact URI shown in System Connections. Local loopback OAuth defaults
# to localhost even when the app is opened through 127.0.0.1.
# Requested scopes depend on the UI toggles:
#   Context: openid email profile https://www.googleapis.com/auth/gmail.readonly
#   Send:    https://www.googleapis.com/auth/gmail.send
#   Drafts:  https://www.googleapis.com/auth/gmail.compose
# GOOGLE_MAIL_CLIENT_ID=
# GOOGLE_MAIL_CLIENT_SECRET=
# GOOGLE_MAIL_REDIRECT_URI=
#
# Microsoft redirect URI:
#   http://localhost:3000/api/v1/mailbox/oauth/microsoft/callback
#   https://your-crmy-host/api/v1/mailbox/oauth/microsoft/callback
# Requested delegated permissions depend on the UI toggles:
#   Context: openid email profile offline_access Mail.Read
#   Send:    Mail.Send
#   Drafts:  Mail.ReadWrite
# MICROSOFT_MAIL_CLIENT_ID=
# MICROSOFT_MAIL_CLIENT_SECRET=
# MICROSOFT_MAIL_REDIRECT_URI=
# MICROSOFT_TENANT_ID=common
#
# ── Calendar OAuth for Customer Activity Context (optional) ──────────────────
#
# Admins can verify selected-provider readiness in Settings → System Connections →
# OAuth and actor coverage in Settings → Actors. Users connect their own calendar from
# /app/activities → Connections after these credentials are configured.
#
# Google Calendar redirect URI:
#   http://localhost:3000/api/v1/calendar/oauth/google/callback
#   https://your-crmy-host/api/v1/calendar/oauth/google/callback
# Use the exact URI shown in System Connections. Local loopback OAuth defaults
# to localhost even when the app is opened through 127.0.0.1.
# Requested scopes:
#   Context: openid email profile https://www.googleapis.com/auth/calendar.readonly
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=
#
# Microsoft Calendar redirect URI:
#   http://localhost:3000/api/v1/calendar/oauth/microsoft/callback
#   https://your-crmy-host/api/v1/calendar/oauth/microsoft/callback
# Requested delegated permissions:
#   Context: openid email profile offline_access Calendars.Read
# MICROSOFT_CALENDAR_CLIENT_ID=
# MICROSOFT_CALENDAR_CLIENT_SECRET=
# MICROSOFT_CALENDAR_REDIRECT_URI=
#
# Systems-of-record connector HTTP timeout. Default: 30000.
# CONNECTOR_FETCH_TIMEOUT_MS=30000
#
# Slack webhook send timeout. Default: 10000.
# SLACK_SEND_TIMEOUT_MS=10000


# ── pgvector semantic search (optional) ───────────────────────────────────────
#
# Adds semantic (vector) similarity search alongside full-text search.
# Supported on: Supabase, Neon, RDS (with pgvector), local Docker (pgvector/pgvector:pg16).
# NOT supported on: standard Railway/Render managed PostgreSQL.
#
# Step 1: Enable the migration (runs once on next server start)
# ENABLE_PGVECTOR=true
#
# Step 2: Configure an embedding provider (Anthropic has no embeddings API)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small      # default for openai
# EMBEDDING_DIMENSIONS=1536                   # must match model; baked into DB column
# EMBEDDING_BASE_URL=                         # override for custom OpenAI-compat server
#
# After enabling, backfill existing entries with the context_embed_backfill MCP tool.
# New entries are embedded automatically when possible; failures queue durable
# background embedding jobs so ingestion can keep working.


# ── Automation engine (optional) ─────────────────────────────────────────────

# Number of consecutive workflow run failures before CRMy automatically creates
# an escalated HITL request in the Handoffs queue. Default: 3.
# WORKFLOW_FAILURE_ALERT_THRESHOLD=3


# ── Seed demo data on container start (Docker only) ──────────────────────────

# Set to "true" to automatically seed rich demo data (3 accounts, 6 contacts,
# 3 opportunities, 10 activities, 12 context entries, 3 assignments) on first
# container start. Useful for demos and development.
# CRMY_SEED_DEMO=true


# ── Dev / seed scripts only ───────────────────────────────────────────────────

# These are read by packages/server/scripts/seed.ts to authenticate before
# loading sample data. Not used by the server itself.
# SEED_EMAIL=admin@crmy.dev
# SEED_PASSWORD=
# API_BASE=http://localhost:3000
