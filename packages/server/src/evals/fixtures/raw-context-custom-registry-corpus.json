[
  {
    "id": "custom_implementation_owner_ready",
    "title": "Custom implementation owner Signal is ready when required details are present",
    "registry": {
      "custom_types": [
        {
          "type_name": "implementation_owner",
          "label": "Implementation Owner",
          "is_extractable": true,
          "json_schema": {
            "type": "object",
            "properties": {
              "person_name": { "type": "string" },
              "responsibility": { "type": "string" },
              "coverage_area": { "type": "string" },
              "confidence_basis": { "type": "string" }
            },
            "required": ["person_name", "responsibility", "coverage_area", "confidence_basis"]
          }
        }
      ]
    },
    "document": "Avery will own the EMEA rollout implementation, coordinate enablement, and report weekly adoption blockers.",
    "expected_signal_types": ["implementation_owner"],
    "expected_readiness": {
      "implementation_owner": "ready_for_memory"
    },
    "golden_model_output": {
      "context_entries": [
        {
          "context_type": "implementation_owner",
          "title": "Avery owns EMEA rollout implementation",
          "body": "Avery will own the EMEA rollout implementation and coordinate enablement.",
          "confidence": 0.88,
          "structured_data": {
            "person_name": "Avery",
            "responsibility": "own rollout implementation and coordinate enablement",
            "coverage_area": "EMEA rollout",
            "confidence_basis": "stated directly in meeting notes"
          },
          "evidence": [{ "source_type": "meeting_notes", "snippet": "Avery will own the EMEA rollout implementation" }]
        }
      ],
      "record_proposals": []
    }
  },
  {
    "id": "custom_implementation_owner_missing_required_detail",
    "title": "Custom implementation owner Signal remains reviewable when required detail is missing",
    "registry": {
      "custom_types": [
        {
          "type_name": "implementation_owner",
          "label": "Implementation Owner",
          "is_extractable": true,
          "json_schema": {
            "type": "object",
            "properties": {
              "person_name": { "type": "string" },
              "responsibility": { "type": "string" },
              "coverage_area": { "type": "string" },
              "confidence_basis": { "type": "string" }
            },
            "required": ["person_name", "responsibility", "coverage_area", "confidence_basis"]
          }
        }
      ]
    },
    "document": "Avery may help with rollout, but the team did not confirm which region or ownership scope.",
    "expected_signal_types": ["implementation_owner"],
    "expected_readiness": {
      "implementation_owner": "needs_more_detail"
    },
    "expected_missing_details": {
      "implementation_owner": ["Coverage Area", "Confidence Basis"]
    },
    "must_not_auto_promote": true,
    "golden_model_output": {
      "context_entries": [
        {
          "context_type": "implementation_owner",
          "title": "Avery may help with rollout",
          "body": "Avery may help with rollout, but ownership scope is not confirmed.",
          "confidence": 0.67,
          "structured_data": {
            "person_name": "Avery",
            "responsibility": "may help with rollout"
          },
          "evidence": [{ "source_type": "meeting_notes", "snippet": "Avery may help with rollout" }]
        }
      ],
      "record_proposals": []
    }
  },
