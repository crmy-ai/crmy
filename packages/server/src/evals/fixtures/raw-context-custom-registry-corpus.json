  {
    "id": "admin_stricter_success_criteria_blocks_incomplete_memory",
    "title": "Admin stricter required fields block incomplete Success Criteria from Memory",
    "registry": {
      "overrides": [
        {
          "type_name": "success_criteria",
          "json_schema": {
            "type": "object",
            "properties": {
              "criterion": { "type": "string" },
              "measurement": { "type": "string" },
              "owner": { "type": "string" },
              "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] }
            },
            "required": ["criterion", "measurement", "owner"]
          }
        }
      ]
    },
    "document": "The customer wants faster rep prep, but did not define the measurement or owner.",
    "expected_signal_types": ["success_criteria"],
    "expected_readiness": {
      "success_criteria": "needs_more_detail"
    },
    "expected_missing_details": {
      "success_criteria": ["Measurement", "Owner"]
    },
    "must_not_auto_promote": true,
    "golden_model_output": {
      "context_entries": [
        {
          "context_type": "success_criteria",
          "title": "Customer wants faster rep prep",
          "body": "The customer wants faster rep prep, but measurement and owner are not defined.",
          "confidence": 0.79,
          "structured_data": {
            "criterion": "faster rep prep"
          },
          "evidence": [{ "source_type": "meeting_notes", "snippet": "wants faster rep prep" }]
        }
      ],
      "record_proposals": []
    }
  }
]
