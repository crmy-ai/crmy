{
  "name": "@crmy/server",
  "version": "0.6.1",
  "description": "CRMy server — Express + PostgreSQL + MCP endpoint",
  "type": "module",
  "files": [
    "dist",
    "migrations",
    "public"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b && node scripts/copy-web.cjs",
    "prepare": "npm run build",
    "dev": "tsx watch --require ./scripts/load-env.cjs src/index.ts",
    "start": "node dist/index.js",
    "generate:openapi": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.0.0",
    "@aws-sdk/client-ses": "^3.1025.0",
    "@crmy/shared": "*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@sendgrid/mail": "^8.1.6",
    "express": "^4.21.0",
    "form-data": "^4.0.5",
    "jose": "^5.9.0",
    "mailgun.js": "^12.7.1",
    "mammoth": "^1.12.0",
    "node-pg-migrate": "^7.9.0",
    "nodemailer": "^6.9.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.0",
    "postmark": "^4.0.7",
    "resend": "^6.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.0.0"
  },
  "license": "Apache-2.0"
}
