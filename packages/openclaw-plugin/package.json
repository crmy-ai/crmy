{
  "name": "@crmy/openclaw-plugin",
  "version": "0.8.6",
  "description": "CRMy plugin for OpenClaw — expose customer context, typed revenue objects, HITL handoffs, and audit-safe writes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepare": "npm run build",
    "dev": "tsup src/index.ts --format esm --watch"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "keywords": [
    "openclaw",
    "customer-context",
    "operational-state",
    "mcp",
    "crmy",
    "plugin",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codycharris/crmy.git"
  }
}
